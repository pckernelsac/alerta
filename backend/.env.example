# Copia a .env y ajusta valores locales
APP_HOST=0.0.0.0
APP_PORT=8000
# Orígenes permitidos para CORS (coma separada). Incluye preview de Vite (4173) si lo usas.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Supabase (opcional hasta conectar el cliente)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
